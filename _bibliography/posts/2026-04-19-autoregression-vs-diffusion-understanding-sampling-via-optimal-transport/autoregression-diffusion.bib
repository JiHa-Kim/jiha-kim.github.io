@misc{vesseronNeuralImplementationBreniers2025,
  title = {On a {{Neural Implementation}} of {{Brenier}}'s {{Polar Factorization}}},
  author = {Vesseron, Nina and Cuturi, Marco},
  year = 2025,
  month = may,
  number = {arXiv:2403.03071},
  eprint = {2403.03071},
  primaryclass = {stat},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2403.03071},
  url = {http://arxiv.org/abs/2403.03071},
  urldate = {2026-04-20},
  abstract = {In 1991, Brenier proved a theorem that generalizes the polar decomposition for square matrices -- factored as PSD \$\textbackslash times\$ unitary -- to any vector field \$F:\textbackslash mathbb\textbraceleft R\textbraceright\textasciicircum d\textbackslash rightarrow \textbackslash mathbb\textbraceleft R\textbraceright\textasciicircum d\$. The theorem, known as the polar factorization theorem, states that any field \$F\$ can be recovered as the composition of the gradient of a convex function \$u\$ with a measure-preserving map \$M\$, namely \$F=\textbackslash nabla u \textbackslash circ M\$. We propose a practical implementation of this far-reaching theoretical result, and explore possible uses within machine learning. The theorem is closely related to optimal transport (OT) theory, and we borrow from recent advances in the field of neural optimal transport to parameterize the potential \$u\$ as an input convex neural network. The map \$M\$ can be either evaluated pointwise using \$u\textasciicircum *\$, the convex conjugate of \$u\$, through the identity \$M=\textbackslash nabla u\textasciicircum * \textbackslash circ F\$, or learned as an auxiliary network. Because \$M\$ is, in general, not injective, we consider the additional task of estimating the ill-posed inverse map that can approximate the pre-image measure \$M\textasciicircum\textbraceleft -1\textbraceright\$ using a stochastic generator. We illustrate possible applications of Brenier's polar factorization to non-convex optimization problems, as well as sampling of densities that are not log-concave.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Machine Learning,Statistics - Machine Learning}
}

